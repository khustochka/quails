-# frozen_string_literal: true
%li
  %small
    = surround('[', ']') do
      = link_to(obs.id, observation_path(obs))
  %b= taxon_link(obs.taxon)
  = name_sci(obs.taxon)
  %small.tag{class: "tag_#{obs.taxon.category}"}= obs.taxon.category
  = obs.quantity
  = obs.notes
  (#{obs.private_notes})
  %b= post_link('POST >>', obs.post)
  - if @attach_core_id
    %span= post_attach_detach_link(obs, @attach_core_id)
  - if obs.voice
    %small.voice.tag voice
  - if obs.hidden
    = tag.span(class: %w(fas fa-eye-slash), title: "Hidden")
