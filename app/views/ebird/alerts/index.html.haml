-# frozen_string_literal: true
- @page_title = "eBird Alerts Map"

- if @missing_sid
  %h1= page_header
  %p
    No alert configured. Set the
    %code EBIRD_ALERT_SID
    environment variable to your eBird alert ID.
- else
  - @body_class = "map-page"
  - @no_viewport = true
  - javascript "admin-maps"
  - stylesheet "map_edit"
  .map-content
    .map-side-panel
      .alerts-panel-header
        %h3 eBird Alerts
        %p
          = link_to "Alert #{@sid}", "https://ebird.org/alert/summary?sid=#{@sid}", target: "_blank", rel: "noopener"
        .alerts-panel-meta
          %span.alerts-last-preload
            - if @not_loaded
              No data loaded
            - elsif @last_preload
              Updated
              = I18n.with_locale(:en) { time_ago_in_words(@last_preload) }
              ago
          = button_to "Refresh", ebird_alerts_refresh_path, method: :post, remote: true, class: "button button--small", form: {id: "ebird_alerts_refresh_form"}
      %ul.alerts-species-list
        - @species&.each do |sp|
          %li{data: {species_code: sp[:code]}}
            .alerts-species-names
              %span.alerts-species-name= sp[:name]
              %span.alerts-species-sci= sp[:sci]
            %span.alerts-species-count= sp[:total_obs]
    .mapContainer
      #googleMap{data: {map_enabled: map_enabled, map_mode: "ebird-alerts", locations: (@locations_json || "[]")}}
