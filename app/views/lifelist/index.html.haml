-# frozen_string_literal: true
- @page_title = t('.title')

- @robots = 'NOINDEX'

- @jumbo_class = "jumbo-lifelist"

- content_for :translated do
  = render 'app2/shared/translated'

-# - content_for :jumbo do
-#   = render 'partials/translated'
-#   %h1= @page_title

-# - content_for :jumbo_side do
-#   %ul.subheader-menu
-#     %li
-#       = link_to t('.records_and_stats'), lifelist_stats_path

- cache(key: Quails::CacheKey.lifelist) do
  .page-container

    = content_for :translated

    = simple_page_header(@page_title)

    .grid.grid-cols-1.md:grid-cols-2.gap-x-8
      %div
        %h2.top5-list-header.font-rubik= link_to("Lifelist", lifelist_path)
        = render partial: "top5list", object: @list_life

      %div
        %h2.top5-list-header.font-rubik= link_to(t("lifelist.title.yearlist", year: Settings.current_year), list_path(year: Settings.current_year))
        = render partial: "top5list", object: @list_current_year

      %div
        %h2.top5-list-header.font-rubik
          = link_to(t("lifelist.title.canada"), list_path(locus: "canada"))
        = render partial: "top5list", object: @list_canada

      %div
        %h2.top5-list-header.font-rubik
          = link_to(t("lifelist.title.ukraine"), list_path(locus: "ukraine"))
        = render partial: "top5list", object: @list_ukraine

    .grid.grid-cols-1.md:grid-cols-2.gap-x-8
      %div
        %h2.top5-list-header.font-rubik
          = link_to(t("lifelist.title.usa"), list_path(locus: "usa"))
          (#{@list_usa.total_count})

      %div.md:order-last
        %h2.top5-list-header.font-rubik
          = link_to(t("lifelist.title.gb"), list_path(locus: "united_kingdom"))
          (#{@list_uk.total_count})

      %div
        %h2.top5-list-header.font-rubik
          = link_to(t("lifelist.title.poland"), list_path(locus: "poland"))
          (#{@list_pl.total_count})
