-# frozen_string_literal: true
- @page_title = @locus.slug

.locus-show
  .locus-header
    %h1
      = @locus.name_en
      - if @locus.loc_type.present?
        %span.tag{class: @locus.loc_type}= @locus.loc_type
    .locus-header-meta
      %code= @locus.slug
      - if @locus.private_loc?
        %span.tag.special private
      - if @locus.five_mile_radius?
        %span.tag.region 5MR

  - content_for :add_shortcuts do
    %li= link_to "Lifelist", advanced_list_path(locus: @locus.slug), target: :_blank, rel: :noopener
  = render "admin/shortcuts" if current_user.admin?

  - if notice
    %p#notice= notice

  - ancestors = @locus.ancestors.to_a
  - if ancestors.any?
    %nav.locus-breadcrumb
      - ancestors.each do |ancestor|
        = link_to ancestor.name_en, ancestor
        %span.sep ›
      %span.current= @locus.name_en

  .locus-columns
    .locus-card
      %h2 Details
      %table.neat_table.locus-details
        %tbody
          %tr
            %th Parent
            %td= @locus.parent.nil? ? "—" : link_to(@locus.parent.name_en, @locus.parent)
          %tr
            %th English name
            %td= @locus.name_en
          %tr
            %th Russian name
            %td= @locus.name_ru
          %tr
            %th Ukrainian name
            %td= @locus.name_uk
          %tr
            %th Full name
            %td= @locus.decorated.full_name
          - if @locus.public_locus && @locus.public_locus != @locus
            %tr
              %th Public full name
              %td= @locus.public_locus.decorated.full_name
          %tr
            %th Coordinates
            %td= latlon_link(@locus)
          - if @locus.iso_code.present?
            %tr
              %th ISO code
              %td= @locus.iso_code
          %tr
            %th Public index
            %td= @locus.public_index || "—"

    .locus-card
      %h2
        Children
        %span.count= @locus.children.size
      - children = @locus.children.order(:name_en)
      - if children.any?
        %ul.locus-children
          - children.each do |child|
            %li
              = link_to child.name_en, child
              - if child.loc_type.present?
                %span.tag{class: child.loc_type}= child.loc_type
        - parent_label = @locus.parent ? @locus.parent.name_en : "the top level"
        .locus-promote
          = button_to "Promote children to #{parent_label}", promote_children_locus_path(@locus.slug),
              method: :post,
              data: {confirm: "Move all #{children.size} children of #{@locus.name_en} up to #{parent_label}, making them siblings of #{@locus.name_en}?"}
          %p.less-important Re-parents every direct child to this locus's parent.
      - else
        %p.empty No children.
