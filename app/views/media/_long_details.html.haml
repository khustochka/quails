-# frozen_string_literal: true
- core_ids_with_available_posts = current_user.available_posts.where(post_core_id: media.post_cores).distinct.pluck(:post_core_id)
- cores = PostCore.where(id: core_ids_with_available_posts)
- localized_posts_map = Post.localized_for(cores, I18n.locale, scope: current_user.available_posts)
- localized_posts = cores.filter_map { |core| localized_posts_map[core.id] }

%p
  %div
    %i<
      %time{ datetime: media.observ_date.iso8601 }= l(media.observ_date, format: :long)
  %div
    = media.decorated.public_locus_full_name

- unless blogless_locale?
  = media.decorated.description

- if localized_posts.present?
  %h3= t(".blog_posts")
  %ul
    - localized_posts.each do |post|
      %li= post_link(post.decorated.title, post, true)
