-# frozen_string_literal: true
%nav.main-menu
  .page-container
    %ul

      %li.screen-hidden.print-only-logo.font-rubik
        birdwatch.org.ua

      %li.print-hidden
        = link_to blog_path, class: "home-link" do
          %i.fas.fa-house-chimney
          .sr-only= t('menu.home-sr-only')

      %li
        = link_to blog_path do
          %span= t('menu.blog')

      %li= link_to t('menu.birds_ukraine'), country_path(country: 'ukraine')

      %li= link_to t('menu.gallery'), gallery_path

      %li= link_to t('menu.map'), map_path

      %li= link_to t('menu.lifelist'), lists_overview_path

      %li= link_to t('menu.links'), links_path

      %li.trans-menu
        = link_to t('menu.english'), root_path(locale: :en), lang: :en, hreflang: :en, class: "translation"
